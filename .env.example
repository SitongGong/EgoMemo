# ===== API Keys =====
# OpenAI (GPT-4o / GPT-5 等)
OPENAI_API_KEY=your-openai-key-here
# DashScope / 阿里云百炼 (Qwen-VL API)
DASHSCOPE_API_KEY=your-dashscope-key-here
# Google / Gemini
GEMINI_API_KEY=your-gemini-key-here
# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key-here
# SiliconFlow / 硅基流动
SILICONFLOW_API_KEY=your-siliconflow-key-here

# ===== 本地模型权重路径 (可选) =====
QWEN3VL_8B_PATH=./pretrained_weights/Qwen3-VL-8B-Instruct
QWEN35_2B_PATH=./pretrained_weights/Qwen3.5-2B
QWEN35_4B_PATH=./pretrained_weights/Qwen3.5-4B
QWEN35_9B_PATH=./pretrained_weights/Qwen3.5-9B

# ===== 数据 / 结果路径 (可选) =====
